    // ── Filtered List ──
    private IEnumerable<JobItem> FilteredJobs
    {
        get
        {
            var result = AllJobs.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
                result = result.Where(j =>
                    j.Role.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.Company.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.Skills.Any(s => s.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));

            if (!string.IsNullOrWhiteSpace(typeFilter))
                result = result.Where(j => j.Type == typeFilter);

            if (!string.IsNullOrWhiteSpace(setupFilter))
                result = result.Where(j => j.Setup == setupFilter);

            result = sortOrder switch
            {
                "Match" => result.OrderByDescending(j => j.MatchPct),
                _ => result
            };

            return result;
        }
    }
}
