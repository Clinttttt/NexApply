@page "/job-board"
@rendermode InteractiveServer
<PageTitle>Job Board — NexApply</PageTitle>

<div class="app-shell">

    <Sidebar />

    <main class="main-content">

        <PageHeader Title="Job Board" Subtitle="@($"{FilteredJobs.Count()} listings — updated today")">
            <div class="header-actions">
                <a href="/browse-jobs" class="btn-browse-for-you">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    Browse For You
                </a>
            </div>
        </PageHeader>

        <div class="job-board-body">

            <!-- ── Left Panel: Search + Job List ── -->
            <div class="job-panel-left">

                <!-- ── Toolbar ── -->
                <div class="jb-toolbar">
                    <div class="search-wrap">
                        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                        <input class="search-input" type="text"
                               placeholder="Search role, company, or skill…"
                               @bind="searchQuery"
                               @bind:event="oninput" />
                    </div>

                    <div class="jb-filters">
                        <select class="filter-select" @bind="typeFilter">
                            <option value="">All Types</option>
                            <option value="Full-time">Full-time</option>
                            <option value="Internship">Internship</option>
                            <option value="Part-time">Part-time</option>
                            <option value="Contract">Contract</option>
                            <option value="Freelance">Freelance</option>
                        </select>
                        <select class="filter-select" @bind="setupFilter">
                            <option value="">All Setups</option>
                            <option value="Remote">Remote</option>
                            <option value="On-site">On-site</option>
                            <option value="Hybrid">Hybrid</option>
                        </select>
                        <select class="filter-select" @bind="sortOrder">
                            <option value="Recent">Most Recent</option>
                            <option value="Match">Best Match</option>
                        </select>

                        @if (!string.IsNullOrWhiteSpace(searchQuery) || !string.IsNullOrWhiteSpace(typeFilter) || !string.IsNullOrWhiteSpace(setupFilter))
                        {
                            <button class="btn-clear-filters" @onclick="ClearFilters">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                                Clear
                            </button>
                        }
                    </div>
                </div>

                <!-- ── Job List ── -->
                <div class="job-list">
                    @{
                        var jobs = FilteredJobs.ToList();
                    }

                    @if (!jobs.Any())
                    {
                        <div class="empty-state">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            <p class="empty-state__title">No jobs found</p>
                            <p class="empty-state__sub">Try adjusting your search or filters.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var job in jobs)
                        {
                            var isActive = selectedJob?.Id == job.Id;
                            <div class="job-card @(isActive ? "job-card--active" : "")" @onclick="() => SelectJob(job)">

                                <div class="job-card__top">
                                    <div class="job-card__info">
                                        <p class="job-card__company">@job.Company</p>
                                        <h3 class="job-card__role">@job.Role</h3>
                                    </div>
                                    <span class="job-card__date">@job.PostedDate</span>
                                </div>

                                <div class="job-card__tags">
                                    <span class="jb-tag jb-tag--type">@job.Type</span>
                                    <span class="jb-tag jb-tag--setup">@job.Setup</span>
                                    <span class="jb-tag jb-tag--location">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                        @job.Location
                                    </span>
                                </div>

                                <p class="job-card__preview">@GetPreviewText(job.About)</p>

                            </div>
                        }
                    }
                </div>

            </div>

            <!-- ── Right Panel: Job Detail ── -->
            <div class="job-panel-right">

                @if (selectedJob == null)
                {
                    <div class="detail-empty">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="7" width="20" height="14" rx="2" />
                            <path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z" />
                        </svg>
                        <p class="detail-empty__title">Select a job to view details</p>
                        <p class="detail-empty__sub">Click any listing from the left to see the full description.</p>
                    </div>
                }
                else
                {
                    <!-- ── Detail Header ── -->
                    <div class="detail-header">
                        <div class="detail-header__left">
                            <div>
                                <p class="detail-company">@selectedJob.Company</p>
                                <h2 class="detail-role">@selectedJob.Role</h2>
                            </div>
                        </div>
                        <div class="detail-header__actions">
                            <button class="btn-save @(selectedJob.IsSaved ? "btn-save--saved" : "")" @onclick="() => ToggleSave(selectedJob)">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="@(selectedJob.IsSaved ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                                </svg>
                                @(selectedJob.IsSaved ? "Saved" : "Save")
                            </button>
                            <button class="btn-apply">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 5v14M5 12l7 7 7-7" />
                                </svg>
                                Apply Now
                            </button>
                        </div>
                    </div>

                    <!-- ── Meta Grid ── -->
                    <div class="detail-meta">
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="14" rx="2" />
                                <path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">TYPE</span>
                                <span class="detail-meta__val">@selectedJob.Type</span>
                            </div>
                        </div>
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">LOCATION</span>
                                <span class="detail-meta__val">@selectedJob.Location</span>
                            </div>
                        </div>
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">POSTED</span>
                                <span class="detail-meta__val">@selectedJob.PostedDate</span>
                            </div>
                        </div>
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">APPLICANTS</span>
                                <span class="detail-meta__val">@selectedJob.Applicants applied</span>
                            </div>
                        </div>
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23" />
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">SALARY</span>
                                <span class="detail-meta__val">@selectedJob.Salary</span>
                            </div>
                        </div>
                        <div class="detail-meta__item">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                            </svg>
                            <div>
                                <span class="detail-meta__key">SETUP</span>
                                <span class="detail-meta__val">@selectedJob.Setup</span>
                            </div>
                        </div>
                    </div>

                    <!-- ── Skills ── -->
                    <div class="detail-section">
                        <h4 class="detail-section__title">Required Skills</h4>
                        <div class="detail-skills">
                            @foreach (var skill in selectedJob.Skills)
                            {
                                <span class="skill-chip">@skill</span>
                            }
                        </div>
                    </div>

                    <!-- ── About ── -->
                    <div class="detail-section">
                        <h4 class="detail-section__title">About this role</h4>
                        <p class="detail-body">@selectedJob.About</p>
                    </div>

                    <!-- ── Responsibilities ── -->
                    <div class="detail-section">
                        <h4 class="detail-section__title">Responsibilities</h4>
                        <ul class="detail-list">
                            @foreach (var item in selectedJob.Responsibilities)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>

                    <!-- ── Requirements ── -->
                    <div class="detail-section">
                        <h4 class="detail-section__title">Requirements</h4>
                        <ul class="detail-list">
                            @foreach (var item in selectedJob.Requirements)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>

                    <!-- ── Bottom Apply ── -->
                    <div class="detail-cta">
                        <button class="btn-apply btn-apply--full">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 5v14M5 12l7 7 7-7" />
                            </svg>
                            Apply Now
                        </button>
                        <button class="btn-save @(selectedJob.IsSaved ? "btn-save--saved" : "") btn-save--full" @onclick="() => ToggleSave(selectedJob)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="@(selectedJob.IsSaved ? "currentColor" : "none")" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                            </svg>
                            @(selectedJob.IsSaved ? "Saved" : "Save Job")
                        </button>
                    </div>
                }

            </div>

        </div>

    </main>

</div>

@code {

    // ── State ──
    private string searchQuery = "";
    private string typeFilter = "";
    private string setupFilter = "";
    private string sortOrder = "Recent";
    private JobItem? selectedJob;

    private void ClearFilters()
    {
        searchQuery = "";
        typeFilter = "";
        setupFilter = "";
    }

    private void SelectJob(JobItem job)
    {
        selectedJob = job;
    }

    private void ToggleSave(JobItem job)
    {
        job.IsSaved = !job.IsSaved;
    }

    private static string GetMatchColor(int pct) => pct >= 80 ? "green" : pct >= 55 ? "amber" : "red";

    private static string GetMatchRingColor(int pct) => pct >= 80 ? "#059669" : pct >= 55 ? "#D97706" : "#DC2626";

    private static string GetPreviewText(string text)
    {
        var sentences = text.Split(new[] { ". " }, StringSplitOptions.RemoveEmptyEntries);
        if (sentences.Length >= 2)
            return sentences[0] + ". " + sentences[1] + ".";
        return text.Length > 120 ? text.Substring(0, 120) + "..." : text;
    }

    // ── Data Model ──
    private class JobItem
    {
        public int Id { get; init; }
        public string Company { get; init; } = "";
        public string Role { get; init; } = "";
        public string Type { get; init; } = "";
        public string Setup { get; init; } = "";
        public string Location { get; init; } = "";
        public string PostedDate { get; init; } = "";
        public string Salary { get; init; } = "";
        public int Applicants { get; init; }
        public int MatchPct { get; init; }
        public string LogoColor { get; init; } = "";
        public string LogoText { get; init; } = "";
        public List<string> Skills { get; init; } = new();
        public string About { get; init; } = "";
        public List<string> Responsibilities { get; init; } = new();
        public List<string> Requirements { get; init; } = new();
        public bool IsSaved { get; set; }
    }

