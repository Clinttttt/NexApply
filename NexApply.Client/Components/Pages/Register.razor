@page "/register"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-shell">

    <!-- ═══════════ LEFT PANEL ═══════════ -->
    <AuthLeftPanel 
        Eyebrow="Join 12,000+ students today"
        Title='Your career<br/><span class="left-title-accent">journey</span><br/>begins now.'
        Subtitle="Create your free account and get matched to internships and jobs that fit your skills automatically." />

    <!-- ═══════════ RIGHT PANEL ═══════════ -->
    <main class="login-right">
        <div class="login-form-wrap">

            <!-- Mobile brand (hidden on desktop) -->
            <div class="mobile-brand">
                <div class="brand-logo brand-logo--dark">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Outer hexagon -->
                        <path d="M14 2L24 8V20L14 26L4 20V8L14 2Z" fill="#1D4ED8"/>
                        <!-- Inner N shape -->
                        <path d="M10 10V18M10 10L18 18M18 18V10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="brand-name brand-name--dark">NexApply</span>
            </div>

            @if (!ShowVerificationStep)
            {
                <!-- REGISTRATION FORM -->
                <h2 class="form-title">Create account</h2>
                <p class="form-sub">Start for free — no credit card needed</p>

                <!-- Role Switcher -->
                <div class="role-switcher">
                    <button class="role-btn @(ActiveRole == "Student" ? "active" : "")"
                            type="button"
                            @onclick='() => SetRole("Student")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                        </svg>
                        Student
                    </button>
                    <button class="role-btn @(ActiveRole == "Recruiter" ? "active" : "")"
                            type="button"
                            @onclick='() => SetRole("Recruiter")'>
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                        </svg>
                        Recruiter
                    </button>
                </div>

                <!-- Google -->
                <button class="google-btn" type="button" @onclick="SignUpWithGoogle">
                    <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Continue with Google
                </button>

                <!-- Divider -->
                <div class="form-divider">
                    <div class="divider-line"></div>
                    <span class="divider-label">or sign up with email</span>
                    <div class="divider-line"></div>
                </div>

                <!-- Error -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-banner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ErrorMessage
                    </div>
                }

                <!-- Form Fields -->
                <div class="form-fields">

                    <!-- Name -->
                    <div class="field-group">
                        <label class="field-label" for="reg-name">
                            @(ActiveRole == "Student" ? "Full name" : "Company name")
                        </label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                @if (ActiveRole == "Student")
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                        <circle cx="12" cy="7" r="4"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                                    </svg>
                                }
                            </div>
                            <input id="reg-name"
                                   class="field-input field-input--prefixed"
                                   type="text"
                                   placeholder='@(ActiveRole == "Student" ? "Juan dela Cruz" : "Acme Corp")'
                                   @bind="DisplayName"
                                   @bind:event="oninput"
                                   autocomplete="name" />
                        </div>
                    </div>

                    <!-- Username -->
                    <div class="field-group">
                        <label class="field-label" for="reg-username">Username</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                            </div>
                            <div class="field-prefix field-at-prefix">@@</div>
                            <input id="reg-username"
                                   class="field-input field-input--at-prefixed"
                                   type="text"
                                   placeholder="juandelacruz"
                                   @bind="Username"
                                   @bind:event="oninput"
                                   autocomplete="username" />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="field-group">
                        <label class="field-label" for="reg-email">Email address</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                            </div>
                            <input id="reg-email"
                                   class="field-input field-input--prefixed"
                                   type="email"
                                   placeholder="you@email.com"
                                   @bind="Email"
                                   @bind:event="oninput"
                                   autocomplete="email" />
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="field-group">
                        <label class="field-label" for="reg-password">Password</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <input id="reg-password"
                                   class="field-input field-input--prefixed"
                                   type="@(ShowPassword ? "text" : "password")"
                                   placeholder="Min. 8 characters"
                                   @bind="Password"
                                   @bind:event="oninput"
                                   autocomplete="new-password" />
                            <button class="field-suffix eye-toggle"
                                    type="button"
                                    @onclick="() => ShowPassword = !ShowPassword"
                                    aria-label="@(ShowPassword ? "Hide" : "Show") password">
                                @if (ShowPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(Password))
                        {
                            <div class="strength-wrap">
                                <div class="strength-bars">
                                    <div class="strength-bar @(PasswordStrength >= 1 ? "strength-bar--" + StrengthColor : "")"></div>
                                    <div class="strength-bar @(PasswordStrength >= 2 ? "strength-bar--" + StrengthColor : "")"></div>
                                    <div class="strength-bar @(PasswordStrength >= 3 ? "strength-bar--" + StrengthColor : "")"></div>
                                    <div class="strength-bar @(PasswordStrength >= 4 ? "strength-bar--" + StrengthColor : "")"></div>
                                </div>
                                <span class="strength-label strength-label--@StrengthColor">@StrengthLabel</span>
                            </div>
                        }
                    </div>

                    <!-- Confirm Password -->
                    <div class="field-group">
                        <label class="field-label" for="reg-confirm">Confirm password</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <input id="reg-confirm"
                                   class='field-input field-input--prefixed @(!string.IsNullOrEmpty(ConfirmPassword) && ConfirmPassword != Password ? "field-input--error" : "")'
                                   type="@(ShowConfirmPassword ? "text" : "password")"
                                   placeholder="Re-enter your password"
                                   @bind="ConfirmPassword"
                                   @bind:event="oninput"
                                   autocomplete="new-password" />
                            <button class="field-suffix eye-toggle"
                                    type="button"
                                    @onclick="() => ShowConfirmPassword = !ShowConfirmPassword"
                                    aria-label="@(ShowConfirmPassword ? "Hide" : "Show") confirm password">
                                @if (ShowConfirmPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(ConfirmPassword) && ConfirmPassword != Password)
                        {
                            <span class="field-hint field-hint--error">Passwords do not match.</span>
                        }
                    </div>

                </div>

                <!-- Terms checkbox -->
                <div class="terms-check-row">
                    <label class="remember-label">
                        <input type="checkbox" class="remember-check" @bind="AgreeToTerms" />
                        I agree to the
                        <a href="/terms" class="signup-link">Terms of Service</a>
                        and
                        <a href="/privacy" class="signup-link">Privacy Policy</a>
                    </label>
                </div>

                <!-- Submit -->
                <button class="submit-btn" type="button" @onclick="HandleRegister" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="submit-spinner"></span>
                        <span>Creating account…</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <line x1="19" y1="8" x2="19" y2="14"/>
                            <line x1="22" y1="11" x2="16" y2="11"/>
                        </svg>
                        <span>Create account</span>
                    }
                </button>

                <!-- Sign in link -->
                <p class="signup-hint">
                    Already have an account?
                    <a href="/login" class="signup-link">Sign in</a>
                </p>
            }
            else
            {
                <!-- EMAIL VERIFICATION STEP -->
                <h2 class="form-title">Verify your email</h2>
                <p class="form-sub">We sent a 6-digit code to <strong>@Email</strong></p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-banner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ErrorMessage
                    </div>
                }

                <div class="form-fields">
                    <div class="field-group">
                        <label class="field-label" for="verify-code">Verification code</label>
                        <div class="field-wrap">
                            <input id="verify-code"
                                   class="field-input"
                                   type="text"
                                   placeholder="000000"
                                   maxlength="6"
                                   @bind="VerificationCode"
                                   @bind:event="oninput"
                                   autocomplete="one-time-code" />
                        </div>
                        <span class="field-hint">Code expires in 10 minutes</span>
                    </div>
                </div>

                <button class="submit-btn" type="button" @onclick="HandleVerifyEmail" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="submit-spinner"></span>
                        <span>Verifying…</span>
                    }
                    else
                    {
                        <span>Verify email</span>
                    }
                </button>

                <p class="signup-hint">
                    Didn't receive the code?
                    <button class="signup-link" style="border:none;background:none;padding:0;cursor:pointer;" @onclick="ResendCode" disabled="@IsResending">
                        @(IsResending ? "Sending..." : "Resend code")
                    </button>
                </p>
            }

        </div>
    </main>

</div>

@code {
    private string ActiveRole = "Student";
    private string DisplayName = "";
    private string Username = "";
    private string Email = "";
    private string Password = "";
    private string ConfirmPassword = "";
    private string VerificationCode = "";
    private bool ShowPassword = false;
    private bool ShowConfirmPassword = false;
    private bool AgreeToTerms = false;
    private bool IsLoading = false;
    private bool IsResending = false;
    private bool ShowVerificationStep = false;
    private string ErrorMessage = "";

    private void SetRole(string role)
    {
        ActiveRole = role;
        DisplayName = "";
        ErrorMessage = "";
    }

    private int PasswordStrength
    {
        get
        {
            if (string.IsNullOrEmpty(Password)) return 0;
            int score = 0;
            if (Password.Length >= 8) score++;
            if (Password.Any(char.IsUpper)) score++;
            if (Password.Any(char.IsDigit)) score++;
            if (Password.Any(c => !char.IsLetterOrDigit(c))) score++;
            return score;
        }
    }

    private string StrengthLabel => PasswordStrength switch
    {
        1 => "Weak",
        2 => "Fair",
        3 => "Good",
        4 => "Strong",
        _ => ""
    };

    private string StrengthColor => PasswordStrength switch
    {
        1 => "red",
        2 => "amber",
        3 => "blue",
        4 => "green",
        _ => ""
    };

    private async Task HandleRegister()
    {
        ErrorMessage = "";

        if (string.IsNullOrWhiteSpace(DisplayName))
        {
            ErrorMessage = ActiveRole == "Student" ? "Please enter your full name." : "Please enter your company name.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Username))
        {
            ErrorMessage = "Please choose a username.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Email))
        {
            ErrorMessage = "Please enter your email address.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password) || Password.Length < 8)
        {
            ErrorMessage = "Password must be at least 8 characters.";
            return;
        }

        if (Password != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        if (!AgreeToTerms)
        {
            ErrorMessage = "Please agree to the Terms of Service to continue.";
            return;
        }

        IsLoading = true;

        var (success, error) = await AuthService.Register(DisplayName, Username, Email, Password, ConfirmPassword, ActiveRole);

        IsLoading = false;

        if (success)
        {
            ShowVerificationStep = true;
        }
        else
        {
            ErrorMessage = error ?? "Registration failed. Please try again.";
        }
    }

    private async Task HandleVerifyEmail()
    {
        ErrorMessage = "";

        if (string.IsNullOrWhiteSpace(VerificationCode) || VerificationCode.Length != 6)
        {
            ErrorMessage = "Please enter the 6-digit verification code.";
            return;
        }

        IsLoading = true;

        var success = await AuthService.VerifyEmail(Email, VerificationCode);

        IsLoading = false;

        if (success)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            ErrorMessage = "Invalid or expired verification code. Please try again.";
        }
    }

    private async Task ResendCode()
    {
        ErrorMessage = "";
        IsResending = true;

        var success = await AuthService.SendVerificationCode(Email);

        IsResending = false;

        if (!success)
        {
            ErrorMessage = "Failed to resend code. Please try again.";
        }
    }

    private void SignUpWithGoogle()
    {
        Navigation.NavigateTo("/api/auth/google-login", forceLoad: true);
    }
}
