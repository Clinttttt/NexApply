@page "/menu"

<div class="app-shell">

    <Sidebar />

    <!-- ── Main Content ── -->
    <main class="main-content">

        <!-- Top Bar -->
        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-title">Dashboard</h1>
                <p class="page-subtitle">Welcome back, Clint — here's your job hunt at a glance.</p>
            </div>
            <div class="topbar-right">
                <div class="search-wrap">
                    <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none">
                        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" />
                        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    <input class="search-input" type="text" placeholder="Search jobs, companies…" />
                </div>
                <button class="notif-btn">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    <span class="notif-indicator"></span>
                </button>
            </div>
        </header>

        <!-- Stat Cards -->
        <section class="stats-grid">

            <!-- Applications -->
            <div class="stat-card stat-card--highlight">
                <div class="stat-header">
                    <span class="stat-label">Applications</span>
                    <span class="stat-icon-wrap blue">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                                  stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </span>
                </div>
                <span class="stat-value">3</span>
                <div class="stat-footer">
                    <span class="stat-trend up">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                        +1 this week
                    </span>
                    <a href="#" class="stat-view-btn stat-view-btn--blue">View</a>
                </div>
            </div>

            <!-- Under Review -->
            <div class="stat-card stat-card--highlight">
                <div class="stat-header">
                    <span class="stat-label">Under Review</span>
                    <span class="stat-icon-wrap amber">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                            <polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </span>
                </div>
                <span class="stat-value">1</span>
                <div class="stat-footer">
                    <span class="stat-trend neutral">No change</span>
                    <a href="#" class="stat-view-btn stat-view-btn--amber">View</a>
                </div>
            </div>

            <!-- Job Matches -->
            <div class="stat-card stat-card--highlight">
                <div class="stat-header">
                    <span class="stat-label">Job Matches</span>
                    <span class="stat-icon-wrap green">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </span>
                </div>
                <span class="stat-value">12</span>
                <div class="stat-footer">
                    <span class="stat-trend up">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                        Resume matched
                    </span>
                    <a href="#" class="stat-view-btn stat-view-btn--green">View</a>
                </div>
            </div>

            <!-- Shortlisted — replaces Profile Views -->
            <div class="stat-card stat-card--highlight">
                <div class="stat-header">
                    <span class="stat-label">Shortlisted</span>
                    <span class="stat-icon-wrap blue">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            <polyline points="22,4 12,14.01 9,11.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                </div>
                <span class="stat-value">1</span>
                <div class="stat-footer">
                    <span class="stat-trend up">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                            <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        </svg>
                        NexaTech Solutions
                    </span>
                    <a href="#" class="stat-view-btn stat-view-btn--blue">View</a>
                </div>
            </div>

        </section>

        <!-- Application Pipeline -->
        <section class="pipeline-section">
            <div class="pipeline-card">
                <div class="pipeline-header">
                    <span class="pipeline-title">Application Pipeline</span>
                    <span class="pipeline-sub">Your 3 applications across all stages</span>
                </div>
                <div class="pipeline-track">
                    <div class="pipeline-step done">
                        <div class="pipeline-step-dot"></div>
                        <div class="pipeline-step-label">Submitted</div>
                        <div class="pipeline-step-count">3</div>
                    </div>
                    <div class="pipeline-connector done"></div>
                    <div class="pipeline-step active">
                        <div class="pipeline-step-dot"></div>
                        <div class="pipeline-step-label">Under Review</div>
                        <div class="pipeline-step-count">1</div>
                    </div>
                    <div class="pipeline-connector"></div>
                    <div class="pipeline-step done pipeline-step--shortlisted">
                        <div class="pipeline-step-dot"></div>
                        <div class="pipeline-step-label">Shortlisted</div>
                        <div class="pipeline-step-count">1</div>
                    </div>
                    <div class="pipeline-connector"></div>
                    <div class="pipeline-step inactive">
                        <div class="pipeline-step-dot"></div>
                        <div class="pipeline-step-label">For Interview</div>
                        <div class="pipeline-step-count">0</div>
                    </div>
                    <div class="pipeline-connector"></div>
                    <div class="pipeline-step inactive pipeline-step--declined">
                        <div class="pipeline-step-dot"></div>
                        <div class="pipeline-step-label">Declined</div>
                        <div class="pipeline-step-count">0</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Lower Grid -->
        <section class="lower-grid">

            <!-- Recent Applications -->
            <div class="card">
                <div class="card-header">
                    <div class="card-header-left">
                        <h2 class="card-title">Recent Applications</h2>
                        <span class="card-count-badge">3 total</span>
                    </div>
                    <a href="#" class="card-link">View all →</a>
                </div>

                <div class="app-list">

                    <div class="app-row">
                        <div class="app-info">
                            <span class="app-job-title">Frontend Developer Intern</span>
                            <span class="app-company">SoftForge Inc. · Remote</span>
                        </div>
                        <div class="app-right">
                            <span class="status-chip review">Under Review</span>
                            <span class="app-date">Apr 5</span>
                        </div>
                    </div>

                    <div class="app-row">
                        <div class="app-info">
                            <span class="app-job-title">Junior .NET Developer</span>
                            <span class="app-company">TechSpark PH · On-site</span>
                        </div>
                        <div class="app-right">
                            <span class="status-chip submitted">Submitted</span>
                            <span class="app-date">Apr 3</span>
                        </div>
                    </div>

                    <div class="app-row app-row--featured">
                        <div class="app-info">
                            <span class="app-job-title">Backend Intern</span>
                            <span class="app-company">NexaTech Solutions · Hybrid</span>
                        </div>
                        <div class="app-right">
                            <span class="status-chip shortlisted">✓ Shortlisted</span>
                            <span class="app-date">Mar 28</span>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Top Matches -->
            <div class="card">
                <div class="card-header">
                    <div class="card-header-left">
                        <h2 class="card-title">Top Job Matches</h2>
                        <span class="card-count-badge">12 found</span>
                    </div>
                    <a href="#" class="card-link">See all →</a>
                </div>

                <div class="match-list">

                    <div class="match-row">
                        <div class="match-body">
                            <div class="match-top">
                                <div class="match-info">
                                    <span class="match-title">Full-Stack Developer Intern</span>
                                    <span class="match-company">CodeBridge Co. · Makati</span>
                                </div>
                                <span class="score-label score-excellent">91%</span>
                            </div>
                            <div class="match-score-wrap">
                                <div class="score-bar-bg">
                                    <div class="score-bar score-bar--excellent" style="width:91%"></div>
                                </div>
                            </div>
                            <div class="match-tags">
                                <span class="match-tag">React</span>
                                <span class="match-tag">C#</span>
                                <span class="match-tag">Full-time</span>
                            </div>
                        </div>
                    </div>

                    <div class="match-row">
                        <div class="match-body">
                            <div class="match-top">
                                <div class="match-info">
                                    <span class="match-title">C# Backend Intern</span>
                                    <span class="match-company">SkyNet Systems · BGC</span>
                                </div>
                                <span class="score-label score-good">84%</span>
                            </div>
                            <div class="match-score-wrap">
                                <div class="score-bar-bg">
                                    <div class="score-bar score-bar--good" style="width:84%"></div>
                                </div>
                            </div>
                            <div class="match-tags">
                                <span class="match-tag">.NET</span>
                                <span class="match-tag">SQL</span>
                                <span class="match-tag">Internship</span>
                            </div>
                        </div>
                    </div>

                    <div class="match-row">
                        <div class="match-body">
                            <div class="match-top">
                                <div class="match-info">
                                    <span class="match-title">Junior Software Engineer</span>
                                    <span class="match-company">Luminary Labs · Remote</span>
                                </div>
                                <span class="score-label score-fair">77%</span>
                            </div>
                            <div class="match-score-wrap">
                                <div class="score-bar-bg">
                                    <div class="score-bar score-bar--fair" style="width:77%"></div>
                                </div>
                            </div>
                            <div class="match-tags">
                                <span class="match-tag">Blazor</span>
                                <span class="match-tag">PostgreSQL</span>
                                <span class="match-tag">Remote</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </section>

    </main>

</div>

