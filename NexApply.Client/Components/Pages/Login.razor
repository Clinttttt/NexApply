@page "/login"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-shell">

    <!-- ═══════════ LEFT PANEL ═══════════ -->
    <AuthLeftPanel 
        Eyebrow="Trusted by 12,000+ students"
        Title='Your next<br/><span class="left-title-accent">opportunity</span><br/>starts here.'
        Subtitle="Browse thousands of listings, track your applications, and let your resume match you to roles automatically." />

    <!-- ═══════════ RIGHT PANEL ═══════════ -->
    <main class="login-right">
        <div class="login-form-wrap">

            <!-- Mobile brand (hidden on desktop) -->
            <div class="mobile-brand">
                <div class="brand-logo brand-logo--dark">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Outer hexagon -->
                        <path d="M14 2L24 8V20L14 26L4 20V8L14 2Z" fill="#1D4ED8"/>
                        <!-- Inner N shape -->
                        <path d="M10 10V18M10 10L18 18M18 18V10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="brand-name brand-name--dark">NexApply</span>
            </div>

            <!-- Heading -->
            <div class="form-head">
                <h2 class="form-title">Welcome back</h2>
                <p class="form-subtitle">Sign in to continue to NexApply</p>
            </div>

            <!-- Role Toggle -->
            <div class="role-toggle" role="group" aria-label="Sign in as">
                <button class="role-btn @(ActiveRole == "Student" ? "active" : "")"
                        @onclick='() => ActiveRole = "Student"'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                    </svg>
                    Student
                </button>
                <button class="role-btn @(ActiveRole == "Recruiter" ? "active" : "")"
                        @onclick='() => ActiveRole = "Recruiter"'>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                    </svg>
                    Recruiter
                </button>
            </div>

            <!-- Google OAuth -->
            <button class="google-btn" @onclick="SignInWithGoogle" type="button">
                <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Continue with Google
            </button>

            <!-- Divider -->
            <div class="form-divider">
                <div class="divider-line"></div>
                <span class="divider-label">or sign in with email</span>
                <div class="divider-line"></div>
            </div>

            <!-- Error Banner -->
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="error-banner" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    @ErrorMessage
                </div>
            }

            <!-- Form Fields — Password first, then Email -->
            <div class="form-fields">

                <!-- Password -->
                <div class="field-group">
                    <label class="field-label" for="login-password">Password</label>
                    <div class="field-wrap">
                        <div class="field-prefix">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </div>
                        <input id="login-password"
                               class="field-input field-input--prefixed"
                               type="@(ShowPassword ? "text" : "password")"
                               placeholder="Enter your password"
                               @bind="Password"
                               @bind:event="oninput"
                               autocomplete="current-password" />
                        <button class="field-suffix eye-toggle"
                                type="button"
                                @onclick="() => ShowPassword = !ShowPassword"
                                aria-label="@(ShowPassword ? "Hide" : "Show") password">
                            @if (ShowPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                <!-- Email / Username -->
                <div class="field-group">
                    <label class="field-label" for="login-email">Email address</label>
                    <div class="field-wrap">
                        <div class="field-prefix">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </div>
                        <input id="login-email"
                               class="field-input field-input--prefixed"
                               type="email"
                               placeholder="you@email.com"
                               @bind="Email"
                               @bind:event="oninput"
                               @onkeydown="HandleEnterKey"
                               autocomplete="email" />
                    </div>
                </div>

            </div>

            <!-- Remember + Forgot -->
            <div class="form-options">
                <label class="remember-label">
                    <input type="checkbox" class="remember-check" @bind="RememberMe" />
                    Keep me signed in
                </label>
                <button class="forgot-btn" type="button" @onclick="ForgotPassword">
                    Forgot password?
                </button>
            </div>

            <!-- Submit -->
            <button class="submit-btn" type="button" @onclick="HandleLogin" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="submit-spinner"></span>
                    <span>Signing in…</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    <span>Sign in</span>
                }
            </button>

            <!-- Create Account -->
            <p class="signup-hint">
                Don't have an account?
                <a href="/register" class="signup-link">Create one — it's free</a>
            </p>

            <!-- Terms -->
            <p class="terms-hint">
                By signing in, you agree to our
                <a href="/terms" class="terms-link">Terms of Service</a>
                and
                <a href="/privacy" class="terms-link">Privacy Policy</a>.
            </p>

        </div>
    </main>

</div>

@code {
    private string ActiveRole = "Student";
    private string Email = "";
    private string Password = "";
    private bool ShowPassword = false;
    private bool RememberMe = false;
    private bool IsLoading = false;
    private string ErrorMessage = "";

    private bool _googleInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_googleInitialized)
        {
            await Task.Delay(1500);
            try
            {
                await JS.InvokeVoidAsync("initGoogleSignIn");
                _googleInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to initialize Google Sign-In: {ex.Message}");
            }
        }
    }

    private async Task HandleLogin()
    {
        ErrorMessage = "";

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter both your email and password.";
            return;
        }

        IsLoading = true;

        var success = await AuthService.Login(Email, Password);

        IsLoading = false;

        if (!success)
        {
            ErrorMessage = "Invalid email or password. Please check your credentials and try again.";
        }
    }

    private void HandleEnterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = HandleLogin();
    }

    private async Task SignInWithGoogle()
    {
        try
        {
            if (!_googleInitialized)
            {
                await JS.InvokeVoidAsync("initGoogleSignIn");
                _googleInitialized = true;
                await Task.Delay(500);
            }
            await JS.InvokeVoidAsync("promptGoogleOneTap");
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to initialize Google Sign-In. Please try again.";
            Console.WriteLine($"Google Sign-In error: {ex.Message}");
        }
    }

    private void ForgotPassword()
    {
        Navigation.NavigateTo("/forgot-password");
    }
}
