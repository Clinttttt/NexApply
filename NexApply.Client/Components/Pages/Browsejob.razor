    // ─────────────────────────────────────────
    //  STATE
    // ─────────────────────────────────────────

    private string SearchQuery { get; set; } = "";
    private string LocationSearch { get; set; } = "";
    private string SortBy { get; set; } = "recent";
    private int MinMatchScore { get; set; } = 0;
    private bool OnlyShowMatched { get; set; } = false;
    private bool ShowSkillPicker { get; set; } = false;
    private string SkillPickerSearch { get; set; } = "";

    private HashSet<string> SelectedJobTypes = new();
    private HashSet<string> SelectedSetups = new();
    private HashSet<string> SelectedLocations = new();
    private HashSet<string> SelectedSkills = new();

    private JobListing? SelectedJob;

    // ─────────────────────────────────────────
    //  COMPUTED
    // ─────────────────────────────────────────

    private List<FilterOption> FilteredLocationOptions =>
        string.IsNullOrWhiteSpace(LocationSearch)
            ? LocationOptions
            : LocationOptions.Where(l => l.Label.Contains(LocationSearch, StringComparison.OrdinalIgnoreCase)).ToList();

    /// Skill picker: filter catalogue by search, hide empty categories
    private Dictionary<string, List<string>> FilteredSkillCategories
    {
        get
        {
            if (string.IsNullOrWhiteSpace(SkillPickerSearch))
                return TechStackCatalogue;

            return TechStackCatalogue
                .ToDictionary(
                    cat => cat.Key,
                    cat => cat.Value
                        .Where(s => s.Contains(SkillPickerSearch, StringComparison.OrdinalIgnoreCase))
                        .ToList())
                .Where(cat => cat.Value.Any())
                .ToDictionary(c => c.Key, c => c.Value);
        }
    }

    private List<string> ActiveFilterChips
    {
        get
        {
            var chips = new List<string>();
            chips.AddRange(SelectedJobTypes);
            chips.AddRange(SelectedSetups);
            chips.AddRange(SelectedLocations);
            chips.AddRange(SelectedSkills);
            if (MinMatchScore > 0) chips.Add($"Match >= {MinMatchScore}%");
            return chips;
        }
    }

    private List<JobListing> FilteredJobs
    {
        get
        {
            var q = AllJobs.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchQuery))
                q = q.Where(j =>
                    j.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.Company.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    j.MatchedSkills.Any(s => s.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

            if (SelectedJobTypes.Any()) q = q.Where(j => SelectedJobTypes.Contains(j.JobType));
            if (SelectedSetups.Any()) q = q.Where(j => SelectedSetups.Contains(j.WorkSetup));
            if (SelectedLocations.Any()) q = q.Where(j => SelectedLocations.Contains(j.Location));

            if (SelectedSkills.Any())
                q = q.Where(j => SelectedSkills.Any(s =>
                    j.MatchedSkills.Contains(s, StringComparer.OrdinalIgnoreCase) ||
                    j.MissingSkills.Contains(s, StringComparer.OrdinalIgnoreCase)));

            if (MinMatchScore > 0) q = q.Where(j => j.MatchScore >= MinMatchScore);
            if (OnlyShowMatched) q = q.Where(j => j.MatchScore > 0);

            return q.ToList();
        }
    }

    private IEnumerable<JobListing> SortedFilteredJobs => SortBy switch
    {
        "match" => FilteredJobs.OrderByDescending(j => j.MatchScore),
        "company" => FilteredJobs.OrderBy(j => j.Company),
        _ => FilteredJobs.OrderByDescending(j => j.Id)
    };

    // ─────────────────────────────────────────
    //  LIFECYCLE
    // ─────────────────────────────────────────

    protected override void OnInitialized() => SelectedJob = AllJobs.First();

    // ─────────────────────────────────────────
    //  HANDLERS
    // ─────────────────────────────────────────

    private void SelectJob(JobListing job) => SelectedJob = job;

    private void ToggleSave(JobListing job) => job.IsSaved = !job.IsSaved;

    private void ToggleSkillPicker()
    {
        ShowSkillPicker = !ShowSkillPicker;
        if (!ShowSkillPicker) SkillPickerSearch = "";
    }

    private void AddSkillFromPicker(string skill)
    {
        if (!DisplayedSkills.Contains(skill, StringComparer.OrdinalIgnoreCase))
            DisplayedSkills.Add(skill);

        // Auto-activate the newly added skill as a filter
        SelectedSkills.Add(skill);
        EnsureSelectedJobVisible();
    }

    private void ToggleJobType(string label)
    {
        if (!SelectedJobTypes.Remove(label)) SelectedJobTypes.Add(label);
        EnsureSelectedJobVisible();
    }

    private void ToggleSetup(string label)
    {
        if (!SelectedSetups.Remove(label)) SelectedSetups.Add(label);
        EnsureSelectedJobVisible();
    }

    private void ToggleLocation(string label)
    {
        if (!SelectedLocations.Remove(label)) SelectedLocations.Add(label);
        EnsureSelectedJobVisible();
    }

    private void ToggleSkill(string skill)
    {
        if (!SelectedSkills.Remove(skill)) SelectedSkills.Add(skill);
        EnsureSelectedJobVisible();
    }

    private void RemoveFilter(string chip)
    {
        SelectedJobTypes.Remove(chip);
        SelectedSetups.Remove(chip);
        SelectedLocations.Remove(chip);
        SelectedSkills.Remove(chip);
        if (chip.StartsWith("Match")) MinMatchScore = 0;
        EnsureSelectedJobVisible();
    }

    private void ClearAllFilters()
    {
        SelectedJobTypes.Clear();
        SelectedSetups.Clear();
        SelectedLocations.Clear();
        SelectedSkills.Clear();
        SearchQuery = "";
        LocationSearch = "";
        MinMatchScore = 0;
        OnlyShowMatched = false;
        ShowSkillPicker = false;
        EnsureSelectedJobVisible();
    }

    private void OnMatchScoreChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            MinMatchScore = val;
        EnsureSelectedJobVisible();
    }

    private void EnsureSelectedJobVisible()
    {
        if (SelectedJob is not null && !FilteredJobs.Any(j => j.Id == SelectedJob.Id))
            SelectedJob = FilteredJobs.FirstOrDefault();
    }

    private static string GetPreviewText(JobListing job)
    {
        var fullText = string.Join(" ", job.Description);
        var sentences = fullText.Split(new[] { ". " }, StringSplitOptions.RemoveEmptyEntries);
        if (sentences.Length >= 2)
            return sentences[0] + ". " + sentences[1] + ".";
        return fullText.Length > 120 ? fullText.Substring(0, 120) + "..." : fullText;
    }

    private static string GetMatchRingColor(int score) => score >= 90 ? "#059669" : score >= 80 ? "#F59E0B" : "#1D4ED8";

    private static string GetMatchColorClass(int score) => score >= 90 ? "match-green" : score >= 80 ? "match-orange" : "match-blue";
