            DetailBody="Based on your location preferences and job type filters, 5 new full-time listings have been posted this week in Makati City and BGC. These include roles in .NET development, backend engineering, and API development.",
            Category="Match", DateGroup="This Week", TimeAgo="Apr 3", IsRead=true,
            IconSvg=IconMatch, IconBg="notif-icon--blue", BadgeCss="badge--blue",
            ActionLabel="5 new jobs", ActionTagCss="tag--match",
            PrimaryAction="Browse Jobs",
