            IconSvg=IconInterview, IconBg="notif-icon--green", BadgeCss="badge--green",
            ActionLabel="For Interview", ActionTagCss="tag--interview",
            PrimaryAction="View Interview Details", SecondaryAction="Add to Calendar",
            MetaItems=new() {
