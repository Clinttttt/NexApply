            DetailBody="Your application to SoftForge Inc. for the Frontend Developer Intern position is now Under Review. This means the hiring team is actively evaluating your profile. You'll be notified when there's an update.",
            Category="Application", DateGroup="Today", TimeAgo="6h ago", IsRead=false,
            IconSvg=IconApplication, IconBg="notif-icon--amber", BadgeCss="badge--amber",
            ActionLabel="Under Review", ActionTagCss="tag--review",
            PrimaryAction="View Application",
            MetaItems=new() {
                ["Company"] = "SoftForge Inc.",
                ["Position"] = "Frontend Developer Intern",
