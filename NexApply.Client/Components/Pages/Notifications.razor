    };

    // ─────────────────────────────────────────
    //  SIDEBAR CATEGORIES
    // ─────────────────────────────────────────

    private List<CategoryItem> Categories => new()
    {
        new() { Key="All",         Label="All Notifications", IconSvg=IconCatAll,      IconCss="cat-icon--slate", Count=AllNotifications.Count, HasUnread=AllNotifications.Any(n=>!n.IsRead) },
        new() { Key="Application", Label="Applications",      IconSvg=IconApplication, IconCss="cat-icon--blue",  Count=AllNotifications.Count(n=>n.Category=="Application"), HasUnread=AllNotifications.Any(n=>n.Category=="Application"&&!n.IsRead) },
        new() { Key="Match",       Label="Job Matches",       IconSvg=IconMatch,       IconCss="cat-icon--green", Count=AllNotifications.Count(n=>n.Category=="Match"), HasUnread=AllNotifications.Any(n=>n.Category=="Match"&&!n.IsRead) },
        new() { Key="Saved",       Label="Saved Jobs",        IconSvg=IconSaved,       IconCss="cat-icon--red",   Count=AllNotifications.Count(n=>n.Category=="Saved"), HasUnread=AllNotifications.Any(n=>n.Category=="Saved"&&!n.IsRead) },
        new() { Key="System",      Label="System",            IconSvg=IconSystem,      IconCss="cat-icon--slate", Count=AllNotifications.Count(n=>n.Category=="System"), HasUnread=false }
    };

    // ─────────────────────────────────────────
    //  STATE
    // ─────────────────────────────────────────

    private string ActiveCategory { get; set; } = "All";
    private string ReadFilter { get; set; } = "all";
    private Notification? SelectedNotif;

    private int UnreadCount => AllNotifications.Count(n => !n.IsRead);

    // ─────────────────────────────────────────
    //  COMPUTED
    // ─────────────────────────────────────────

    private List<Notification> DisplayedNotifications
    {
        get
        {
            var q = AllNotifications.AsEnumerable();

            if (ActiveCategory != "All")
                q = q.Where(n => n.Category == ActiveCategory);

            q = ReadFilter switch
            {
                "unread" => q.Where(n => !n.IsRead),
                "read" => q.Where(n => n.IsRead),
                _ => q
            };

            return q.ToList();
        }
    }

    private Dictionary<string, List<Notification>> GroupedNotifications =>
        DisplayedNotifications
            .GroupBy(n => n.DateGroup)
            .ToDictionary(g => g.Key, g => g.ToList());

    // ─────────────────────────────────────────
    //  LIFECYCLE
    // ─────────────────────────────────────────

    protected override void OnInitialized() => SelectedNotif = AllNotifications.First();

    // ─────────────────────────────────────────
    //  HANDLERS
    // ─────────────────────────────────────────

    private void SelectNotif(Notification n)
    {
        SelectedNotif = n;
        n.IsRead = true;   // auto-mark as read on open
    }

    private void MarkRead(Notification n) => n.IsRead = true;

    private void MarkAllRead()
    {
        foreach (var n in AllNotifications) n.IsRead = true;
    }

    private void DismissNotif(Notification n)
    {
        AllNotifications.Remove(n);
        if (SelectedNotif?.Id == n.Id)
            SelectedNotif = DisplayedNotifications.FirstOrDefault();
    }

    private void ClearAll()
    {
        AllNotifications.RemoveAll(n => n.IsRead);
        if (SelectedNotif is not null && !AllNotifications.Contains(SelectedNotif))
            SelectedNotif = DisplayedNotifications.FirstOrDefault();
    }
}
