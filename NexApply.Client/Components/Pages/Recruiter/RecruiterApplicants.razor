    private string GetMatchClass(int score) => score >= 80 ? "high" : score >= 60 ? "mid" : "low";
    private string GetStageClass(string stage) => Stages.TryGetValue(stage, out var s) ? s.CssClass : "submitted";
    private string GetAvatarColor(int id) => new[] { "blue", "green", "amber", "slate", "purple" }[id % 5];
    private string FormatType(string type) => type switch { "FullTime" => "Full-Time", "PartTime" => "Part-Time", _ => type };

    private record StageStyle(string CssClass);

    private class JobItem
