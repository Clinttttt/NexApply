    protected override void OnInitialized()
    {
        if (JobId.HasValue) SelectedJobId = JobId;
        ApplyFilters();
    }

    private void SelectJob(int? id)
    {
        SelectedJobId = id;
        ExpandedApplicantId = null;
        ApplyFilters();
    }

    private void ToggleListingsDropdown()
    {
        ShowListingsDropdown = !ShowListingsDropdown;
    }

    private void SelectJobFromDropdown(int? id)
    {
        SelectedJobId = id;
        ExpandedApplicantId = null;
        ShowListingsDropdown = false;
        ApplyFilters();
    }

    private void SetStageFilter(string stage)
    {
        ActiveStageFilter = stage;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var query = SearchQuery?.Trim().ToLower() ?? "";

        FilteredApplicants = Applicants
            .Where(a =>
                (SelectedJobId == null || a.JobId == SelectedJobId) &&
                (string.IsNullOrEmpty(ActiveStageFilter) || a.Stage == ActiveStageFilter) &&
                (string.IsNullOrEmpty(query) ||
                    a.Name.ToLower().Contains(query) ||
                    a.Email.ToLower().Contains(query) ||
                    a.Skills.Any(s => s.ToLower().Contains(query)))
            )
            .OrderBy(a => SortBy switch
            {
                "name" => a.Name,
                _ => ""
            })
            .ThenByDescending(a => SortBy switch
            {
                "newest" => a.AppliedDate.Ticks,
                "oldest" => long.MaxValue - a.AppliedDate.Ticks,
                "match" => (long)a.MatchScore,
                _ => 0L
            })
            .ToList();
    }

    private void ToggleExpand(int id)
    {
        ExpandedApplicantId = ExpandedApplicantId == id ? null : id;
    }

    private void ToggleSelect(int id)
    {
        if (!SelectedApplicantIds.Remove(id))
            SelectedApplicantIds.Add(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool?)e.Value == true)
            SelectedApplicantIds = FilteredApplicants.Select(a => a.Id).ToHashSet();
        else
            SelectedApplicantIds.Clear();
    }

    private void ClearSelection()
    {
        SelectedApplicantIds.Clear();
        BulkStageTarget = "";
    }

    private void ApplyBulkStage()
    {
        if (string.IsNullOrEmpty(BulkStageTarget)) return;
        foreach (var a in Applicants.Where(a => SelectedApplicantIds.Contains(a.Id)))
            a.Stage = BulkStageTarget;
        ClearSelection();
        ApplyFilters();
    }

    private void OnStageChanged(ApplicantItem app) => ApplyFilters();

    private void QuickStage(ApplicantItem app, string stage)
    {
        app.Stage = app.Stage == stage ? "Submitted" : stage;
        ApplyFilters();
    }

