    protected override void OnInitialized()
    {
        FilterConversations();
        // Auto-open first conversation
        if (FilteredConversations.Count > 0)
            SelectConversation(FilteredConversations[0].Id);
    }

    private void FilterConversations()
    {
        var q = ConvSearch?.Trim().ToLower() ?? "";
        FilteredConversations = Conversations
            .Where(c =>
                (string.IsNullOrEmpty(q) ||
                    c.Name.ToLower().Contains(q) ||
                    c.JobTitle.ToLower().Contains(q) ||
                    c.LastMessage.ToLower().Contains(q)) &&
                ConvTab switch
                {
                    "Unread"     => !c.IsRead,
                    "Candidates" => c.Role == "Candidate",
                    _            => true
                }
            )
            .OrderByDescending(c => c.LastMessageAt)
            .ToList();
    }

    private void SetConvTab(string tab) { ConvTab = tab; FilterConversations(); }

    private void SelectConversation(int id)
    {
        ActiveConvId = id;
        ShowTemplates = false;
        var conv = Conversations.FirstOrDefault(c => c.Id == id);
        if (conv != null) conv.IsRead = true;
    }

    private void SendMessage()
    {
        if (string.IsNullOrWhiteSpace(ComposeText) || ActiveConversation == null) return;

        ActiveConversation.Messages.Add(new MessageItem
        {
            Id = ActiveConversation.Messages.Count + 1,
            SenderId = "me",
            Content = ComposeText.Trim(),
            SentAt = DateTime.Now
        });

        ActiveConversation.LastMessage = ComposeText.Trim();
        ActiveConversation.LastMessageAt = DateTime.Now;
        ActiveConversation.LastSenderIsMe = true;
        ComposeText = "";
        ShowTemplates = false;
    }

    private void HandleComposeKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) SendMessage();
    }

    private void OpenNewMessage()
    {
        // TODO: open new message modal
    }

    private void ToggleTemplates() => ShowTemplates = !ShowTemplates;

    private void UseTemplate(MessageTemplate tmpl)
    {
        if (ActiveConversation == null) return;
        ComposeText = tmpl.Body
            .Replace("{name}", ActiveConversation.Name.Split(' ')[0])
            .Replace("{position}", ActiveConversation.JobTitle);
        ShowTemplates = false;
    }

    // ---- Schedule Interview Modal state ----
    private bool ShowScheduleModal = false;
    private ScheduleInterviewModal.InterviewData ModalInterview = new();
    private TimeOnly ModalInterviewTime = new TimeOnly(10, 0);
    private string ModalInterviewerName = "";

    private void OpenScheduleModal(ConversationItem? conv)
    {
        // Pre-fill from the active conversation
        ModalInterview = new ScheduleInterviewModal.InterviewData
        {
            CandidateName = conv?.Name ?? "",
            JobTitle      = conv?.JobTitle ?? "",
            ScheduledAt   = DateTime.Today.AddDays(1),
            DurationMins  = 60,
            Format        = "",
            Location      = "",
            Notes         = ""
        };
        ModalInterviewTime    = new TimeOnly(10, 0);
        ModalInterviewerName  = "";
        ShowScheduleModal     = true;
    }

    private void CloseScheduleModal() => ShowScheduleModal = false;

    private async Task HandleScheduleConfirm(ScheduleInterviewModal.ScheduleResult result)
    {
        ShowScheduleModal = false;

        if (ActiveConversation == null) return;

        var iv = result.Interview;
        var scheduledAt = iv.ScheduledAt.Date
            .AddHours(result.InterviewTime.Hour)
            .AddMinutes(result.InterviewTime.Minute);
        var endTime = scheduledAt.AddMinutes(iv.DurationMins);

        // Build the interview-invite card message
        var inviteMsg = new MessageItem
        {
            Id        = ActiveConversation.Messages.Count + 1,
            SenderId  = "me",
            Type      = "interview-invite",
            Content   = $"Please find your interview details below. The session will be {iv.DurationMins} minutes{(string.IsNullOrWhiteSpace(iv.Location) ? "." : $" via {iv.Format}.")}",
            SentAt    = DateTime.Now,
            InviteDetails = new InterviewInviteDetails
            {
                Position    = iv.JobTitle,
                DateDisplay = scheduledAt.ToString("dddd, MMMM d, yyyy"),
                TimeDisplay = $"{scheduledAt:h:mm tt} – {endTime:h:mm tt}",
                Format      = string.IsNullOrWhiteSpace(iv.Location)
                                  ? iv.Format
                                  : $"{iv.Format} · {iv.Location}"
            }
        };

        ActiveConversation.Messages.Add(inviteMsg);
        ActiveConversation.LastMessage     = "📅 Interview Invitation sent";
        ActiveConversation.LastMessageAt   = DateTime.Now;
        ActiveConversation.LastSenderIsMe  = true;
        ActiveConversation.IsRead          = true;

        await Task.CompletedTask; // keep async signature for EventCallback
    }

    private string FormatTime(DateTime dt)
    {
        if (dt.Date == DateTime.Today) return dt.ToString("h:mm tt");
        if (dt.Date == DateTime.Today.AddDays(-1)) return "Yesterday";
        if ((DateTime.Today - dt.Date).TotalDays < 7) return dt.ToString("ddd");
        return dt.ToString("MMM d");
    }

    private string GetDateLabel(DateTime date)
    {
        if (date == DateTime.Today) return "Today";
        if (date == DateTime.Today.AddDays(-1)) return "Yesterday";
        return date.ToString("dddd, MMMM d");
    }

