        new[] { "blue", "green", "amber", "slate", "purple" }[id % 5];

    private string GetMatchClass(int score) =>
        score >= 80 ? "high" : score >= 60 ? "mid" : "low";

    private void UseShortlistTemplate()
    {
        var template = MessageTemplates.FirstOrDefault(t => t.Name == "Shortlist Notification");
        if (template != null) UseTemplate(template);
    }

    // ---- Models ----
    private class ConversationItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string JobTitle { get; set; } = "";
        public bool IsRead { get; set; }
        public bool IsOnline { get; set; }
        public bool LastSenderIsMe { get; set; }
        public string LastMessage { get; set; } = "";
        public DateTime LastMessageAt { get; set; }
        public string? ApplicationStage { get; set; }
        public int MatchScore { get; set; }
        public int? ApplicantId { get; set; }
        public DateTime? AppliedDate { get; set; }
        public List<string>? Skills { get; set; }
        public List<MessageItem> Messages { get; set; } = new();
        public string Initials => string.Join("", Name.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : ""));
    }

    private class MessageItem
    {
        public int Id { get; set; }
        public string SenderId { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime SentAt { get; set; }
        public string Type { get; set; } = "text";
        public InterviewInviteDetails? InviteDetails { get; set; }
    }

    private class InterviewInviteDetails
    {
        public string Position { get; set; } = "";
        public string DateDisplay { get; set; } = "";
        public string TimeDisplay { get; set; } = "";
        public string Format { get; set; } = "";
    }

    private class MessageTemplate
    {
        public string Name { get; set; } = "";
        public string Body { get; set; } = "";
    }
