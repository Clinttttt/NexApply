    // Group filtered interviews by month
    private Dictionary<DateTime, List<InterviewItem>> GroupedInterviews =>
        FilteredInterviews
            .GroupBy(i => new DateTime(i.ScheduledAt.Year, i.ScheduledAt.Month, 1))
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderBy(i => i.ScheduledAt).ToList());

    // Calendar cells (null = empty padding cell)
    private List<DateTime?> CalendarCells
    {
        get
        {
            var cells = new List<DateTime?>();
            var first = new DateTime(CalendarDate.Year, CalendarDate.Month, 1);
            var days = DateTime.DaysInMonth(CalendarDate.Year, CalendarDate.Month);
            for (int i = 0; i < (int)first.DayOfWeek; i++) cells.Add(null);
            for (int d = 1; d <= days; d++) cells.Add(new DateTime(CalendarDate.Year, CalendarDate.Month, d));
            return cells;
        }
    }

    protected override void OnInitialized() => ApplyFilters();

    private void ApplyFilters()
    {
        var q = SearchQuery?.Trim().ToLower() ?? "";

        FilteredInterviews = Interviews
            .Where(i =>
                (string.IsNullOrEmpty(q) ||
                    i.CandidateName.ToLower().Contains(q) ||
                    i.JobTitle.ToLower().Contains(q)) &&
                (string.IsNullOrEmpty(StatusFilter) || i.Status == StatusFilter) &&
                (string.IsNullOrEmpty(FormatFilter) || i.Format == FormatFilter) &&
                (!SelectedCalendarDate.HasValue || i.ScheduledAt.Date == SelectedCalendarDate.Value.Date) &&
                ActiveTab switch
                {
                    "Today" => i.ScheduledAt.Date == DateTime.Today,
                    "Upcoming" => i.ScheduledAt.Date > DateTime.Today && i.Status == "Scheduled",
                    "Completed" => i.Status == "Completed",
                    "Cancelled" => i.Status is "Cancelled" or "No-show",
                    _ => true
                }
            )
            .OrderBy(i => i.ScheduledAt)
            .ToList();
    }

    private void SetTab(string tab) { ActiveTab = tab; ApplyFilters(); }

    private int GetTabCount(string tab) => tab switch
    {
        "Today" => Interviews.Count(i => i.ScheduledAt.Date == DateTime.Today),
        "Upcoming" => Interviews.Count(i => i.ScheduledAt.Date > DateTime.Today && i.Status == "Scheduled"),
        "Completed" => CompletedCount,
        "Cancelled" => CancelledCount,
        _ => Interviews.Count
    };

    private string GetGroupLabel(DateTime monthStart)
    {
        return monthStart.ToString("MMMM yyyy").ToUpper();
    }

    private void ToggleExpand(int id) =>
        ExpandedInterviewId = ExpandedInterviewId == id ? null : id;

    private async Task SaveFeedback(InterviewItem iv)
    {
        EditingFeedbackId = null;
        
        // TODO: Call your API here to save feedback
        // Example:
        // await HttpClient.PutAsJsonAsync($"/api/interviews/{iv.Id}/feedback", new { Feedback = iv.Feedback });
        
        // For now, feedback is already saved in the local object via @bind
        // When you integrate with API, add the HTTP call here
    }

    private void MarkComplete(InterviewItem iv) { iv.Status = "Completed"; ApplyFilters(); }
    private void CancelInterview(InterviewItem iv) { iv.Status = "Cancelled"; ApplyFilters(); }
    private void OpenReschedule(InterviewItem iv)
    {
        RescheduleInterview = iv;
        IsRescheduleMode = true;
        NewInterview = new InterviewItem
        {
            CandidateName = iv.CandidateName,
            JobTitle = iv.JobTitle,
            ScheduledAt = iv.ScheduledAt.Date,
            DurationMins = iv.DurationMins,
            Format = iv.Format,
            Location = iv.Location,
            MeetingLink = iv.MeetingLink,
            Notes = iv.Notes
        };
        NewInterviewTime = new TimeOnly(iv.ScheduledAt.Hour, iv.ScheduledAt.Minute);
        NewInterviewerName = iv.Interviewers.FirstOrDefault() ?? "";
        ShowScheduleModal = true;
    }

    private void PrevMonth() => CalendarDate = CalendarDate.AddMonths(-1);
    private void NextMonth() => CalendarDate = CalendarDate.AddMonths(1);

    private bool HasInterviewOn(DateTime date) =>
        Interviews.Any(i => i.ScheduledAt.Date == date.Date);

    private void SelectCalendarDay(DateTime? date)
    {
        if (!date.HasValue) return;
        SelectedCalendarDate = SelectedCalendarDate?.Date == date.Value.Date ? null : date.Value;
        ApplyFilters();
    }

    private void ClearCalendarSelection() { SelectedCalendarDate = null; ApplyFilters(); }

    private void CloseScheduleModal() 
    { 
        ShowScheduleModal = false; 
        IsRescheduleMode = false;
        RescheduleInterview = null;
        NewInterview = new(); 
        NewInterviewerName = ""; 
    }

    private void ConfirmSchedule()
    {
        if (string.IsNullOrWhiteSpace(NewInterview.CandidateName) ||
            string.IsNullOrWhiteSpace(NewInterview.JobTitle) ||
            string.IsNullOrWhiteSpace(NewInterview.Format)) return;

        if (IsRescheduleMode && RescheduleInterview != null)
        {
            // Update existing interview
            RescheduleInterview.CandidateName = NewInterview.CandidateName;
            RescheduleInterview.JobTitle = NewInterview.JobTitle;
            RescheduleInterview.ScheduledAt = NewInterview.ScheduledAt.Date
                .AddHours(NewInterviewTime.Hour)
                .AddMinutes(NewInterviewTime.Minute);
            RescheduleInterview.DurationMins = NewInterview.DurationMins;
            RescheduleInterview.Format = NewInterview.Format;
            RescheduleInterview.Location = NewInterview.Location;
            RescheduleInterview.MeetingLink = NewInterview.MeetingLink;
            RescheduleInterview.Notes = NewInterview.Notes;
            RescheduleInterview.Interviewers = string.IsNullOrWhiteSpace(NewInterviewerName)
                ? RescheduleInterview.Interviewers
                : new() { NewInterviewerName.Trim() };
        }
        else
        {
            // Create new interview
            NewInterview.Id = Interviews.Count > 0 ? Interviews.Max(i => i.Id) + 1 : 1;
            NewInterview.Status = "Scheduled";
            NewInterview.ScheduledAt = NewInterview.ScheduledAt.Date
                .AddHours(NewInterviewTime.Hour)
                .AddMinutes(NewInterviewTime.Minute);
            NewInterview.Interviewers = string.IsNullOrWhiteSpace(NewInterviewerName) 
                ? new() { "Anna Vidal" } 
                : new() { NewInterviewerName.Trim() };
            Interviews.Add(NewInterview);
        }
        
        CloseScheduleModal();
        ApplyFilters();
    }

    private string GetFormatIcon(string format) => format switch
    {
        "Video Call" => "📹",
        "On-site" => "🏢",
        "Phone" => "📞",
        _ => "📋"
    };

    private string GetAvatarColor(int id) =>
        new[] { "blue", "green", "amber", "slate", "purple" }[id % 5];

    private class InterviewItem
    {
        public int Id { get; set; }
        public string CandidateName { get; set; } = "";
        public string JobTitle { get; set; } = "";
        public DateTime ScheduledAt { get; set; } = DateTime.Today.AddHours(10);
        public int DurationMins { get; set; } = 60;
        public string Format { get; set; } = "";
        public string Status { get; set; } = "Scheduled";
        public string Location { get; set; } = "";
        public string MeetingLink { get; set; } = "";
        public List<string> Interviewers { get; set; } = new();
        public string Notes { get; set; } = "";
        public string Feedback { get; set; } = "";
        public int Rating { get; set; } = 0;
        public string Recommendation { get; set; } = "";
        public string Initials => string.Join("", CandidateName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : ""));
    }
