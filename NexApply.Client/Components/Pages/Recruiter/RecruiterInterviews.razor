            ScheduledAt = DateTime.Today.AddDays(-2).AddHours(15), DurationMins = 30, Format = "Phone",
            Status = "Cancelled", Location = "", MeetingLink = "",
            Interviewers = new() { "Marcus Lee" },
            Notes = "Candidate withdrew application.", Feedback = "", Rating = 0, Recommendation = ""
        },
