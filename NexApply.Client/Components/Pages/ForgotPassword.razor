@page "/forgot-password"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-shell">

    <!-- ═══════════ LEFT PANEL ═══════════ -->
    <AuthLeftPanel 
        Eyebrow="Trusted by 12,000+ students"
        Title='Reset your<br/><span class="left-title-accent">password</span><br/>securely.'
        Subtitle="Enter your email address and we'll send you a code to reset your password." />

    <!-- ═══════════ RIGHT PANEL ═══════════ -->
    <main class="login-right">
        <div class="login-form-wrap">

            <!-- Mobile brand (hidden on desktop) -->
            <div class="mobile-brand">
                <div class="brand-logo brand-logo--dark">
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M14 2L24 8V20L14 26L4 20V8L14 2Z" fill="#1D4ED8"/>
                        <path d="M10 10V18M10 10L18 18M18 18V10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span class="brand-name brand-name--dark">NexApply</span>
            </div>

            @if (!ShowResetStep)
            {
                <!-- REQUEST RESET CODE -->
                <h2 class="form-title">Forgot password?</h2>
                <p class="form-sub">No worries, we'll send you reset instructions</p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-banner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ErrorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="success-banner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        @SuccessMessage
                    </div>
                }

                <div class="form-fields">
                    <div class="field-group">
                        <label class="field-label" for="reset-email">Email address</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                            </div>
                            <input id="reset-email"
                                   class="field-input field-input--prefixed"
                                   type="email"
                                   placeholder="you@email.com"
                                   @bind="Email"
                                   @bind:event="oninput"
                                   autocomplete="email" />
                        </div>
                    </div>
                </div>

                <button class="submit-btn" type="button" @onclick="HandleSendResetCode" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="submit-spinner"></span>
                        <span>Sending…</span>
                    }
                    else
                    {
                        <span>Send reset code</span>
                    }
                </button>

                <p class="signup-hint">
                    <a href="/login" class="signup-link">← Back to login</a>
                </p>
            }
            else
            {
                <!-- RESET PASSWORD WITH CODE -->
                <h2 class="form-title">Reset password</h2>
                <p class="form-sub">Enter the code sent to <strong>@Email</strong></p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-banner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ErrorMessage
                    </div>
                }

                <div class="form-fields">
                    <div class="field-group">
                        <label class="field-label" for="reset-code">Reset code</label>
                        <div class="field-wrap">
                            <input id="reset-code"
                                   class="field-input"
                                   type="text"
                                   placeholder="000000"
                                   maxlength="6"
                                   @bind="ResetCode"
                                   @bind:event="oninput"
                                   autocomplete="one-time-code" />
                        </div>
                        <span class="field-hint">Code expires in 10 minutes</span>
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="new-password">New password</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <input id="new-password"
                                   class="field-input field-input--prefixed"
                                   type="@(ShowPassword ? "text" : "password")"
                                   placeholder="Min. 8 characters"
                                   @bind="NewPassword"
                                   @bind:event="oninput"
                                   autocomplete="new-password" />
                            <button class="field-suffix eye-toggle"
                                    type="button"
                                    @onclick="() => ShowPassword = !ShowPassword">
                                @if (ShowPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="confirm-password">Confirm password</label>
                        <div class="field-wrap">
                            <div class="field-prefix">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </div>
                            <input id="confirm-password"
                                   class='field-input field-input--prefixed @(!string.IsNullOrEmpty(ConfirmPassword) && ConfirmPassword != NewPassword ? "field-input--error" : "")'
                                   type="@(ShowConfirmPassword ? "text" : "password")"
                                   placeholder="Re-enter your password"
                                   @bind="ConfirmPassword"
                                   @bind:event="oninput"
                                   autocomplete="new-password" />
                            <button class="field-suffix eye-toggle"
                                    type="button"
                                    @onclick="() => ShowConfirmPassword = !ShowConfirmPassword">
                                @if (ShowConfirmPassword)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(ConfirmPassword) && ConfirmPassword != NewPassword)
                        {
                            <span class="field-hint field-hint--error">Passwords do not match.</span>
                        }
                    </div>
                </div>

                <button class="submit-btn" type="button" @onclick="HandleResetPassword" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="submit-spinner"></span>
                        <span>Resetting…</span>
                    }
                    else
                    {
                        <span>Reset password</span>
                    }
                </button>

                <p class="signup-hint">
                    Didn't receive the code?
                    <button class="signup-link" style="border:none;background:none;padding:0;cursor:pointer;" @onclick="HandleSendResetCode" disabled="@IsResending">
                        @(IsResending ? "Sending..." : "Resend code")
                    </button>
                </p>
            }

        </div>
    </main>

</div>

@code {
    private string Email = "";
    private string ResetCode = "";
    private string NewPassword = "";
    private string ConfirmPassword = "";
    private bool ShowPassword = false;
    private bool ShowConfirmPassword = false;
    private bool IsLoading = false;
    private bool IsResending = false;
    private bool ShowResetStep = false;
    private string ErrorMessage = "";
    private string SuccessMessage = "";

    private async Task HandleSendResetCode()
    {
        ErrorMessage = "";
        SuccessMessage = "";

        if (string.IsNullOrWhiteSpace(Email))
        {
            ErrorMessage = "Please enter your email address.";
            return;
        }

        IsLoading = true;
        IsResending = true;

        // TODO: Call API to send reset code
        await Task.Delay(1000);

        IsLoading = false;
        IsResending = false;

        // Simulate success
        ShowResetStep = true;
        SuccessMessage = "Reset code sent! Check your email.";
    }

    private async Task HandleResetPassword()
    {
        ErrorMessage = "";

        if (string.IsNullOrWhiteSpace(ResetCode) || ResetCode.Length != 6)
        {
            ErrorMessage = "Please enter the 6-digit reset code.";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewPassword) || NewPassword.Length < 8)
        {
            ErrorMessage = "Password must be at least 8 characters.";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        IsLoading = true;

        // TODO: Call API to reset password
        await Task.Delay(1000);

        IsLoading = false;

        // Simulate success
        Navigation.NavigateTo("/login");
    }
}
