@page "/resume&profile"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IProfileApiService ProfileApi
@inject NavigationManager Navigation
@inject PersistentComponentState ApplicationState
@inject CurrentUserService CurrentUser
@using NexApply.Contracts.Profile.Commands
@using NexApply.Contracts.Profile.Dtos
@using NexApply.Client.Interfaces
@using NexApply.Client.Utilities
@implements IDisposable

<PageTitle>Resume & Profile — NexApply</PageTitle>

<!-- Hidden file input for resume upload -->
<InputFile id="resumeFileInput" OnChange="HandleResumeUpload" accept=".pdf,.docx,.jpg,.jpeg,.png" style="display:none" />

<div class="app-shell">

    <Sidebar />

    <main class="main-content">

        <PageHeader Title="Resume & Profile" Subtitle="Manage your professional information and resume">
            @if (!IsEditingProfile)
            {
                <a href="/browse-jobs" class="btn-browse">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" />
                        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    Browse More Jobs
                </a>
            }
            @if (IsEditingProfile)
            {
                <div class="header-actions">
                    <button class="btn-outline" @onclick="CancelEditProfile">Cancel</button>
                    <button class="btn-primary" @onclick="SaveProfile">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" />
                            <polyline points="17 21 17 13 7 13 7 21" />
                            <polyline points="7 3 7 8 15 8" />
                        </svg>
                        Save Changes
                    </button>
                </div>
            }
        </PageHeader>

        <div class="profile-body">
            @if (IsLoading)
            {
                <div style="display: flex; justify-content: center; align-items: center; min-height: 400px; color: #64748B;">
                    <div style="text-align: center;">
                        <svg class="spin-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 12px;">
                            <path d="M21 12a9 9 0 11-6.219-8.56" />
                        </svg>
                        <div>Loading profile...</div>
                    </div>
                </div>
            }
            else if (LoadError != null)
            {
                <div style="display: flex; justify-content: center; align-items: center; min-height: 400px; color: #DC2626;">
                    <div style="text-align: center;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 12px;">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <div>@LoadError</div>
                        <button class="btn-primary" style="margin-top: 16px;" @onclick="LoadProfileData">Retry</button>
                    </div>
                </div>
            }
            else
            {
            <div class="profile-grid">

                <!-- ═══ LEFT COLUMN ═══ -->
                <div class="left-col">

                    <!-- Profile Card -->
                    <div class="card profile-card">

                        <div class="avatar-section">
                            <div class="avatar-wrap">
                                <div class="avatar-circle">CV</div>
                                @if (IsEditingProfile)
                                {
                                    <button class="avatar-edit-btn" title="Change photo">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                    </button>
                                }
                            </div>
                            <div class="identity-meta">
                                <div class="identity-name">@FullName</div>
                                <span class="identity-role-badge">Student</span>
                            </div>
                            @if (!IsEditingProfile)
                            {
                                <button class="edit-profile-btn" @onclick="StartEditProfile">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                    Edit
                                </button>
                            }
                        </div>

                        <div class="divider"></div>

                        @if (!IsEditingProfile)
                        {
                            <!-- VIEW MODE -->
                            <div class="profile-info-list">
                                <div class="info-row">
                                    <span class="info-icon">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                                    </span>
                                    <div>
                                        <div class="info-label">Email</div>
                                        <div class="info-value">@Email</div>
                                    </div>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
                                    </span>
                                    <div>
                                        <div class="info-label">Phone</div>
                                        <div class="info-value @(string.IsNullOrEmpty(Phone) ? "info-empty" : "")">
                                            @(string.IsNullOrEmpty(Phone) ? "Add phone number" : Phone)
                                        </div>
                                    </div>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                                    </span>
                                    <div>
                                        <div class="info-label">Location</div>
                                        <div class="info-value @(string.IsNullOrEmpty(Location) ? "info-empty" : "")">
                                            @(string.IsNullOrEmpty(Location) ? "Add your location" : Location)
                                        </div>
                                    </div>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" /></svg>
                                    </span>
                                    <div>
                                        <div class="info-label">LinkedIn</div>
                                        @if (!string.IsNullOrEmpty(LinkedIn))
                                        {
                                            <a class="info-link" href="https://linkedin.com/in/@LinkedIn" target="_blank">linkedin.com/in/@LinkedIn</a>
                                        }
                                        else
                                        {
                                            <div class="info-value info-empty">Add LinkedIn profile</div>
                                        }
                                    </div>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" /></svg>
                                    </span>
                                    <div>
                                        <div class="info-label">GitHub</div>
                                        @if (!string.IsNullOrEmpty(GitHub))
                                        {
                                            <a class="info-link" href="https://github.com/@GitHub" target="_blank">github.com/@GitHub</a>
                                        }
                                        else
                                        {
                                            <div class="info-value info-empty">Add GitHub profile</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- EDIT MODE -->
                            <div class="form-group">
                                <label class="form-label">Full Name</label>
                                <input class="form-input" type="text" @bind="FullName" @bind:event="oninput" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Email</label>
                                <input class="form-input" type="email" value="@Email" disabled title="Email cannot be changed" style="opacity: 0.6; cursor: not-allowed;" />
                                <small style="color: #64748B; font-size: 11px; margin-top: 4px; display: block;">Email is linked to your account and cannot be changed here</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Phone</label>
                                <input class="form-input" type="tel" @bind="Phone" @bind:event="oninput" placeholder="+63 912 345 6789" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Location</label>
                                <input class="form-input" type="text" @bind="Location" @bind:event="oninput" placeholder="City, Province" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">LinkedIn</label>
                                <div class="input-prefix-wrap">
                                    <span class="input-prefix">linkedin.com/in/</span>
                                    <input class="form-input prefix-input" type="text" @bind="LinkedIn" @bind:event="oninput" placeholder="yourprofile" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">GitHub</label>
                                <div class="input-prefix-wrap">
                                    <span class="input-prefix">github.com/</span>
                                    <input class="form-input prefix-input" type="text" @bind="GitHub" @bind:event="oninput" placeholder="yourusername" />
                                </div>
                            </div>
                        }

                    </div>

                    <!-- Profile Strength -->
                    <div class="card profile-strength-card">
                        <div class="card-label">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                            Profile Strength
                        </div>
                        <div class="strength-bar-wrap">
                            <div class="strength-bar">
                                <div class="strength-fill" style="width: @(ProfileStrength)%;"></div>
                            </div>
                            <span class="strength-pct">@(ProfileStrength)%</span>
                        </div>
                        <div class="strength-checklist">
                            <div class="strength-item @(HasBasicInfo ? "done" : "")">
                                @if (HasBasicInfo)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /></svg>
                                }
                                Basic info completed
                            </div>
                            <div class="strength-item @(HasResume ? "done" : "")">
                                @if (HasResume)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /></svg>
                                }
                                Resume uploaded
                            </div>
                            <div class="strength-item @(HasEducation ? "done" : "")">
                                @if (HasEducation)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /></svg>
                                }
                                Add education
                            </div>
                            <div class="strength-item @(HasEnoughSkills ? "done" : "")">
                                @if (HasEnoughSkills)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /></svg>
                                }
                                Add skills (3+ recommended)
                            </div>
                            <div class="strength-item @(HasAbout ? "done" : "")">
                                @if (HasAbout)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /></svg>
                                }
                                Write about me
                            </div>
                        </div>
                    </div>

                </div>

                <!-- ═══ RIGHT COLUMN: Resume Builder ═══ -->
                <div class="right-col">

                    <div class="card resume-builder-card">

                        <div class="resume-builder-header">
                            <div class="card-label">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                Resume
                            </div>
                            <div class="resume-header-actions">
                                <!-- Mode tabs -->
                                <div class="resume-mode-tabs">
                                    <button class="resume-mode-tab @(ResumeMode == "upload" ? "active" : "")"
                                            @onclick='() => ResumeMode = "upload"'>
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                                        Upload
                                    </button>
                                    <button class="resume-mode-tab @(ResumeMode == "build" ? "active" : "")"
                                            @onclick='() => ResumeMode = "build"'>
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                        Build
                                    </button>
                                </div>

                                <!-- Upload status (shown only in upload mode) -->
                                @if (ResumeMode == "upload")
                                {
                                    @if (IsUploadingResume)
                                    {
                                        <span class="status-badge status-blue">
                                            <svg class="spin-icon" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56" /></svg>
                                            Uploading...
                                        </span>
                                    }
                                    else if (!string.IsNullOrEmpty(UploadedFileDataUrl))
                                    {
                                        <span class="status-badge status-green">
                                            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                            Uploaded
                                        </span>
                                        <button class="btn-ghost-sm" @onclick="TriggerFileUpload" title="Replace file">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                                            Replace
                                        </button>
                                    }
                                }

                                <!-- Build mode: Edit / Lock toggle -->
                                @if (ResumeMode == "build")
                                {
                                    <button class="btn-ghost-sm resume-edit-toggle @(IsEditingResume ? "active" : "")"
                                            @onclick="ToggleResumeEdit"
                                            title="@(IsEditingResume ? "Lock resume" : "Edit resume")">
                                        @if (IsEditingResume)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                <path d="M7 11V7a5 5 0 0110 0v4" />
                                            </svg>
                                            <text>Lock</text>
                                        }
                                        else
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                            <text>Edit</text>
                                        }
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Upload error/success toast -->
                        @if (!string.IsNullOrEmpty(UploadMessage))
                        {
                            <div class="upload-toast @(UploadSuccess ? "toast-success" : "toast-error")">
                                @if (UploadSuccess)
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                }
                                @UploadMessage
                            </div>
                        }

                        <!-- ══ UPLOAD MODE: display the file as-is ══ -->
                        <div style="display: @(ResumeMode == "upload" ? "block" : "none")">
                            @if (string.IsNullOrEmpty(UploadedFileDataUrl))
                            {
                                <div class="resume-upload-zone" @onclick="TriggerFileUpload">
                                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="upload-zone-icon">
                                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                                        <polyline points="17 8 12 3 7 8" />
                                        <line x1="12" y1="3" x2="12" y2="15" />
                                    </svg>
                                    <div class="upload-zone-title">Upload your resume</div>
                                    <div class="upload-zone-sub">PDF, DOCX, JPG, or PNG · Max 5 MB</div>
                                    <div class="upload-zone-note">
                                        Want to build one from scratch? Switch to the <strong>Build</strong> tab.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="resume-file-preview">
                                    @if (UploadedFileType == "image")
                                    {
                                        <img src="@UploadedFileDataUrl" alt="Uploaded Resume" class="resume-preview-img" />
                                    }
                                    else if (UploadedFileType == "pdf")
                                    {
                                        <iframe src="@UploadedFileDataUrl" class="resume-preview-iframe" title="Resume PDF"></iframe>
                                    }
                                    else
                                    {
                                        <div class="resume-docx-card">
                                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                                                <polyline points="14 2 14 8 20 8" />
                                            </svg>
                                            <div class="resume-docx-name">@UploadedFileName</div>
                                            <div class="resume-docx-sub">Word document uploaded. Browser preview not available.</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- ══ BUILD MODE: ResumeDocument component ══ -->
                        <div style="display: @(ResumeMode == "build" ? "block" : "none")">
                            <ResumeDocument @ref="_resumeDoc" IsEditing="IsEditingResume" OnDataChanged="HandleResumeDataChanged" />
                        </div>

                    </div>

                </div>

            </div>
            }
        </div>

    </main>
</div>

@code {

    /* ─── Persistent State ─── */
    private PersistingComponentStateSubscription _persistingSubscription;

    /* ─── Loading State ─── */
    private bool IsLoading = true;
    private string? LoadError = null;
    private bool _resumeContentLoaded = false;

    /* ─── Profile ─── */
    private bool IsEditingProfile = false;
    private string FullName = "";
    private string Email = "";
    private string Phone = "";
    private string Location = "";
    private string LinkedIn = "";
    private string GitHub = "";

    private string _snapFullName = "", _snapEmail = "", _snapPhone = "",
                   _snapLocation = "", _snapLinkedIn = "", _snapGitHub = "";

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        // Get email from authenticated user
        Email = await CurrentUser.GetEmailAsync();

        // Try to restore state first
        if (!ApplicationState.TryTakeFromJson<StudentProfileDto>("profileData", out var restoredProfile))
        {            
            await LoadProfileData();
        }
        else
        {
            // Restore from persisted state
            FullName = restoredProfile?.FullName ?? "";
            Phone = restoredProfile?.Phone ?? "";
            Location = restoredProfile?.Location ?? "";
            LinkedIn = restoredProfile?.LinkedIn ?? "";
            GitHub = restoredProfile?.GitHub ?? "";

            if (!string.IsNullOrEmpty(restoredProfile?.ResumeFilePath))
            {
                ResumeMode = "upload";
                UploadedFileName = restoredProfile.ResumeFilePath;
            }

            IsLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_resumeContentLoaded)
        {
            await LoadResumeContent();
            _resumeContentLoaded = true;
        }
    }

    private Task PersistState()
    {
        var profileData = new StudentProfileDto
        {
            FullName = FullName,
            Phone = Phone,
            Location = Location,
            LinkedIn = LinkedIn,
            GitHub = GitHub,
            ResumeFilePath = UploadedFileName
        };

        ApplicationState.PersistAsJson("profileData", profileData);
        ApplicationState.PersistAsJson("resumeMode", ResumeMode);
        ApplicationState.PersistAsJson("isEditingProfile", IsEditingProfile);
        ApplicationState.PersistAsJson("isEditingResume", IsEditingResume);

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistingSubscription.Dispose();
    }

    private async Task LoadProfileData()
    {
        IsLoading = true;
        LoadError = null;
        StateHasChanged();

        var profileResult = await ProfileApi.GetStudentProfile();
        if (profileResult.IsSuccess && profileResult.Value != null)
        {
            var profile = profileResult.Value;
            FullName = profile.FullName;
            Phone = profile.Phone ?? "";
            Location = profile.Location ?? "";
            LinkedIn = profile.LinkedIn ?? "";
            GitHub = profile.GitHub ?? "";

            // Check if user has uploaded resume
            if (!string.IsNullOrEmpty(profile.ResumeFilePath))
            {
                ResumeMode = "upload";
                // Load the uploaded resume file path
                UploadedFileName = profile.ResumeFilePath;
            }
        }
        else
        {
            LoadError = profileResult.Error ?? "Failed to load profile";
        }

        IsLoading = false;
        StateHasChanged();
    }

    private async Task LoadResumeContent()
    {
        if (_resumeDoc == null) return;

        var resumeResult = await ProfileApi.GetResumeContent();
        if (resumeResult.IsSuccess && resumeResult.Value != null)
        {
            await _resumeDoc.LoadResumeContent(resumeResult.Value);
            StateHasChanged(); // Update profile strength after loading
        }
    }

    private void HandleResumeDataChanged()
    {
        StateHasChanged(); // Recalculate profile strength when resume data changes
    }

    private void StartEditProfile()
    {
        _snapFullName = FullName; _snapEmail = Email; _snapPhone = Phone;
        _snapLocation = Location; _snapLinkedIn = LinkedIn; _snapGitHub = GitHub;
        IsEditingProfile = true;
    }

    private void CancelEditProfile()
    {
        FullName = _snapFullName; Email = _snapEmail; Phone = _snapPhone;
        Location = _snapLocation; LinkedIn = _snapLinkedIn; GitHub = _snapGitHub;
        IsEditingProfile = false;
    }

    private async Task SaveProfile()
    {
        var command = new UpdateStudentProfileCommand(
            FullName,
            Phone,
            Location,
            null, // University
            null, // Course
            null, // GraduationYear
            LinkedIn,
            GitHub,
            null  // Portfolio
        );

        var result = await ProfileApi.UpdateStudentProfile(command);
        if (result.IsSuccess)
        {
            IsEditingProfile = false;
            StateHasChanged();
        }
        else
        {
            // Show error message
            Console.WriteLine($"Failed to save profile: {result.Error}");
        }
    }

    /* ─── Resume Edit/Lock ─── */
    private bool IsEditingResume = false;

    private async Task ToggleResumeEdit()
    {
        if (IsEditingResume && _resumeDoc != null)
        {
            // Switching from Edit to Lock - save all resume data
            await _resumeDoc.SaveResumeData();
        }
        IsEditingResume = !IsEditingResume;
    }

    // ── @ref to ResumeDocument so we can read its computed state ──
    private ResumeDocument? _resumeDoc;

    /* ─── Profile Strength (computed) ─── */
    private bool HasBasicInfo => !string.IsNullOrWhiteSpace(FullName)
                                 && !string.IsNullOrWhiteSpace(Email)
                                 && !string.IsNullOrWhiteSpace(Phone)
                                 && !string.IsNullOrWhiteSpace(Location);

    private bool HasResume => !string.IsNullOrEmpty(UploadedFileDataUrl) || !string.IsNullOrEmpty(UploadedFileName) || (_resumeDoc?.HasName ?? false);
    private bool HasEducation => _resumeDoc?.HasEducation ?? false;
    private bool HasEnoughSkills => _resumeDoc?.HasEnoughSkills ?? false;
    private bool HasAbout => _resumeDoc?.HasAbout ?? false;

    private int ProfileStrength
    {
        get
        {
            int score = 0;
            if (HasBasicInfo) score += 20;
            if (HasResume) score += 20;
            if (HasEducation) score += 20;
            if (HasEnoughSkills) score += 20;
            if (HasAbout) score += 20;
            return score;
        }
    }

    /* ─── Resume Mode ─── */
    private string ResumeMode = "build"; // Default to build mode

    /* ─── File Upload (Upload Mode) ─── */
    private bool IsUploadingResume = false;
    private string UploadMessage = "";
    private bool UploadSuccess = false;
    private string UploadedFileDataUrl = "";
    private string UploadedFileType = "";
    private string UploadedFileName = "";

    private async Task TriggerFileUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('resumeFileInput').click()");
    }

    private async Task HandleResumeUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        var allowedExtensions = new[] { ".pdf", ".docx", ".jpg", ".jpeg", ".png" };

        if (!allowedExtensions.Contains(ext))
        {
            UploadMessage = "Only PDF, DOCX, JPG, or PNG files are accepted.";
            UploadSuccess = false;
            StateHasChanged();
            await Task.Delay(4000);
            UploadMessage = "";
            return;
        }

        if (file.Size > 5 * 1024 * 1024)
        {
            UploadMessage = "File size must be under 5 MB.";
            UploadSuccess = false;
            StateHasChanged();
            await Task.Delay(4000);
            UploadMessage = "";
            return;
        }

        // Check if user has existing resume data (education, work experience, or skills)
        bool hasExistingResumeData = (_resumeDoc?.HasEducation ?? false) || 
                                     (_resumeDoc?.HasEnoughSkills ?? false) ||
                                     (_resumeDoc?.HasAbout ?? false);

        if (hasExistingResumeData)
        {
            // Show confirmation dialog
            bool confirmed = await JS.InvokeAsync<bool>("confirm", 
                "You already have resume data in the template builder. Uploading a file will replace it. Do you want to continue?");
            
            if (!confirmed)
            {
                return; // User cancelled
            }
        }

        IsUploadingResume = true;
        UploadMessage = "";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            string mimeType;
            if (ext == ".pdf")
            {
                mimeType = "application/pdf";
                UploadedFileType = "pdf";
            }
            else if (ext == ".jpg" || ext == ".jpeg")
            {
                mimeType = "image/jpeg";
                UploadedFileType = "image";
            }
            else if (ext == ".png")
            {
                mimeType = "image/png";
                UploadedFileType = "image";
            }
            else
            {
                mimeType = "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
                UploadedFileType = "docx";
            }

            // Upload to API
            var command = new UploadResumeCommand(file.Name, mimeType, fileBytes);
            var result = await ProfileApi.UploadResume(command);

            if (result.IsSuccess && result.Value != null)
            {
                var base64 = Convert.ToBase64String(fileBytes);
                UploadedFileDataUrl = $"data:{mimeType};base64,{base64}";
                UploadedFileName = file.Name;
                ResumeMode = "upload";
                UploadSuccess = true;
                UploadMessage = $"'{file.Name}' uploaded successfully!";
            }
            else
            {
                UploadSuccess = false;
                UploadMessage = result.Error ?? "Failed to upload resume";
            }
        }
        catch (Exception ex)
        {
            UploadSuccess = false;
            UploadMessage = "An error occurred while uploading the file.";
            Console.WriteLine($"Upload error: {ex.Message}");
        }
        finally
        {
            IsUploadingResume = false;
            StateHasChanged();
            await Task.Delay(5000);
            UploadMessage = "";
            StateHasChanged();
        }
    }

}