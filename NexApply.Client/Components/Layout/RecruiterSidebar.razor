<aside class="rec-sidebar" aria-label="Recruiter navigation">

    <!-- Brand -->
    <div class="rec-brand">
        <div class="rec-brand-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M14 2L24 8V20L14 26L4 20V8L14 2Z" fill="#1D4ED8"/>
                <path d="M10 10V18M10 10L18 18M18 18V10" stroke="white" stroke-width="2.5"
                      stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <span class="rec-brand-name">NexApply</span>
        <span class="rec-brand-pill">Recruiter</span>
    </div>

    <!-- Company Card -->
    <div class="rec-company-card">
        <div class="rec-company-avatar" aria-label="CodeBridge Co. logo">
            <span>CB</span>
        </div>
        <div class="rec-company-meta">
            <span class="rec-company-name">CodeBridge Co.</span>
            <span class="rec-company-role">Hiring Manager</span>
        </div>
        <button class="rec-company-chevron" title="Company settings" aria-label="Open company settings">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </button>
    </div>

    <!-- Navigation -->
    <nav class="rec-nav" aria-label="Recruiter menu">

        <p class="rec-nav-label">Manage</p>

        <a href="/recruiter/menu" class="rec-nav-item @(IsActive("/recruiter-menu") ? "is-active" : "")"
           aria-current="@(IsActive("/recruiter-menu") ? "page" : null)">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                </svg>
            </span>
            Dashboard
        </a>

        <a href="/recruiter/post-job" class="rec-nav-item @(IsActive("/recruiter/post-job") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Post a Job
            <span class="rec-nav-badge-blue" aria-label="New feature">New</span>
        </a>

        <a href="/recruiter/manage-jobs" class="rec-nav-item @(IsActive("/recruiter/manage-jobs") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
                    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Manage Jobs
            <span class="rec-nav-count" aria-label="4 active jobs">4</span>
        </a>

        <a href="/recruiter/applicants" class="rec-nav-item @(IsActive("/recruiter/applicants") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            Applicants
            <span class="rec-nav-count rec-nav-count--alert" aria-label="12 applicants">12</span>
        </a>

        <a href="/recruiter/interviews" class="rec-nav-item @(IsActive("/recruiter/interviews") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                    <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </span>
            Interviews
            <span class="rec-nav-dot" aria-label="Upcoming interviews indicator"></span>
        </a>

        <p class="rec-nav-label" style="margin-top: 1.25rem;">Communication</p>

        <a href="/recruiter/messages" class="rec-nav-item @(IsActive("/recruiter/messages") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            Messages
            <span class="rec-nav-count" aria-label="3 unread messages">3</span>
        </a>

        <p class="rec-nav-label" style="margin-top: 1.25rem;">Account</p>

        <a href="/recruiter/company-profile" class="rec-nav-item @(IsActive("/recruiter/company-profile") ? "is-active" : "")">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            Company Profile
        </a>

    </nav>

    <!-- Footer -->
    <div class="rec-sidebar-footer">
        <a href="/recruiter/settings" class="rec-nav-item">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"
                          stroke="currentColor" stroke-width="2"/>
                </svg>
            </span>
            Settings
        </a>

        <a href="/logout" class="rec-nav-item rec-nav-item--logout">
            <span class="rec-nav-icon" aria-hidden="true">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
            Log Out
        </a>
    </div>

</aside>

@code {
    [Inject] private NavigationManager? Navigation { get; set; }

    private string CurrentPath => Navigation?.Uri.Replace(Navigation.BaseUri, "/") ?? string.Empty;

    private bool IsActive(string path)
    {
        if (string.IsNullOrEmpty(CurrentPath)) return false;
        return CurrentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }
}
